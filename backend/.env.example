# Copy this file to .env and fill in your API keys
OPENAI_API_KEY=sk-...
SEMANTIC_SCHOLAR_API_KEY=...

# Tavily — used to look up real reagent prices from supplier websites
# Get your key at: https://tavily.com
TAVILY_API_KEY=tvly-...

# Supabase (for the feedback / learning loop + material price cache)
# Get these from: supabase.com → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Supabase table required for price caching ──────────────────────────────────
# Run this SQL in your Supabase project (SQL Editor → New query):
#
#   CREATE TABLE material_prices (
#       catalog_number TEXT NOT NULL,
#       supplier       TEXT NOT NULL,
#       name           TEXT,
#       unit_price     FLOAT NOT NULL,
#       source         TEXT DEFAULT 'llm',
#       updated_at     TIMESTAMPTZ DEFAULT NOW(),
#   );
# ──────────────────────────────────────────────────────────────────────────────

# Resend (for emailing material quotes)
RESEND_API_KEY=re_...
FROM_EMAIL=onboarding@resend.dev
